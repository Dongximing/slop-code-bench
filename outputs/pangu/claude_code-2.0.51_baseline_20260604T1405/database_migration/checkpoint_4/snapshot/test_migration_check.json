{
  "version": 8,
  "description": "Add age validation constraint",
  "operations": [
    {
      "type": "add_column",
      "table": "users",
      "column": {
        "name": "age",
        "type": "INTEGER",
        "not_null": false
      }
    },
    {
      "type": "add_check_constraint",
      "table": "users",
      "name": "chk_users_age",
      "expression": "age IS NULL OR (age >= 0 AND age <= 150)"
    }
  ]
}
