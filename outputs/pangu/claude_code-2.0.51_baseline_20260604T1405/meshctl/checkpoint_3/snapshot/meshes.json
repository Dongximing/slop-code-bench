{
  "alpha-mesh": {
    "metadata": {
      "name": "alpha-mesh"
    },
    "spec": {
      "instances": 2,
      "resources": {
        "memory": {
          "limit": "1Gi",
          "request": "1Gi"
        }
      },
      "access": {
        "authentication": {
          "enabled": true
        }
      },
      "migration": {
        "strategy": "FullStop"
      }
    },
    "status": {
      "state": "Running"
    }
  },
  "test-cpu": {
    "metadata": {
      "name": "test-cpu"
    },
    "spec": {
      "instances": 2,
      "resources": {
        "memory": {
          "limit": "256Mi",
          "request": "256Mi"
        },
        "cpu": {
          "limit": "2000m",
          "request": "2000m"
        }
      },
      "access": {
        "authentication": {
          "enabled": true
        }
      },
      "migration": {
        "strategy": "FullStop"
      }
    },
    "status": {
      "state": "Running"
    }
  }
}