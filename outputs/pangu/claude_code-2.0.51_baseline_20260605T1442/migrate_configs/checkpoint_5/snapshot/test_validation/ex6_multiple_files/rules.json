{
  "require_environment": {
    "type": "require_keys",
    "scope": "validation",
    "keys": ["environment"]
  },
  "validate_env_values": {
    "type": "validate_value",
    "scope": "validation",
    "key": "environment",
    "constraint": {
      "enum": ["development", "production"]
    }
  }
}
