{
  "version": 1,
  "description": "Test drop operations",
  "operations": [
    {
      "type": "create_table",
      "table": "products",
      "columns": [
        {"name": "id", "type": "INTEGER", "primary_key": true, "auto_increment": true},
        {"name": "name", "type": "TEXT", "not_null": true},
        {"name": "price", "type": "INTEGER"}
      ]
    },
    {
      "type": "create_table",
      "table": "orders",
