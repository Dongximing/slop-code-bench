      },
      "on_delete": "CASCADE"
    },
    {
      "type": "drop_foreign_key",
      "table": "orders",
      "name": "fk_orders_product_id"
    },
    {
      "type": "create_index",
      "name": "idx_orders_product_id",
      "table": "orders",
      "columns": ["product_id"],
      "unique": false
    },
    {
      "type": "drop_index",
      "name": "idx_orders_product_id"
    }
  ]
