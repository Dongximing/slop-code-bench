{
  "version": 100,
  "description": "Full test with all features",
  "operations": [
    {
      "type": "create_table",
      "table": "users",
      "columns": [
        {"name": "id", "type": "INTEGER", "primary_key": true, "auto_increment": true},
        {"name": "name", "type": "TEXT", "not_null": true},
        {"name": "email", "type": "TEXT", "not_null": true},
        {"name": "age", "type": "INTEGER"}
      ]
    },
    {
      "type": "add_check_constraint",
      "table": "users",
      "name": "chk_users_age",
      "expression": "age >= 0 AND age <= 150"
    },
    {
      "type": "create_table",
      "table": "posts",
      "columns": [
        {"name": "id", "type": "INTEGER", "primary_key": true, "auto_increment": true},
        {"name": "user_id", "type": "INTEGER", "not_null": true},
        {"name": "title", "type": "TEXT", "not_null": true},
        {"name": "content", "type": "TEXT", "not_null": false}
      ]
    },
    {
      "type": "add_foreign_key",
      "table": "posts",
      "name": "fk_posts_user_id",
      "columns": ["user_id"],
      "references": {
        "table": "users",
        "columns": ["id"]
      },
      "on_delete": "CASCADE"
    },
    {
      "type": "create_index",
      "name": "idx_posts_user_id",
      "table": "posts",
      "columns": ["user_id"],
      "unique": false
    },
    {
      "type": "create_table",
      "table": "comments",
      "columns": [
        {"name": "id", "type": "INTEGER", "primary_key": true, "auto_increment": true},
        {"name": "post_id", "type": "INTEGER", "not_null": true},
        {"name": "user_id", "type": "INTEGER", "not_null": true},
        {"name": "content", "type": "TEXT", "not_null": true},
        {"name": "created_at", "type": "TIMESTAMP", "default": "CURRENT_TIMESTAMP"}
      ]
    },
    {
      "type": "add_foreign_key",
      "table": "comments",
      "name": "fk_comments_post_id",
      "columns": ["post_id"],
      "references": {
        "table": "posts",
        "columns": ["id"]
      },
      "on_delete": "CASCADE"
    },
    {
      "type": "add_foreign_key",
      "table": "comments",
      "name": "fk_comments_user_id",
      "columns": ["user_id"],
      "references": {
        "table": "users",
        "columns": ["id"]
      },
      "on_delete": "CASCADE"
    },
    {
      "type": "create_index",
      "name": "idx_comments_post_id",
      "table": "comments",
      "columns": ["post_id"],
      "unique": false
    },
    {
      "type": "create_index",
      "name": "idx_comments_user_id",
      "table": "comments",
      "columns": ["user_id"],
      "unique": false
    }
  ]
}
